# Configurações do Servidor
PORT=3000

# Banco de Dados MySQL
# Para usar com XAMPP, crie o banco de dados e atualize a URL abaixo
# DATABASE_URL="mysql://usuario:senha@127.0.0.1:3306/nome_do_banco"

# Exemplo com XAMPP:
# DATABASE_URL="mysql://root:@127.0.0.1:3306/tarefas_db"

# JWT (para uso futuro)
# JWT_SECRET=sua_chave_secreta_aqui

# Ambiente
NODE_ENV=development
